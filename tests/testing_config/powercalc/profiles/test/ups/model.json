{
  "name": "Test UPS",
  "device_type": "ups",
  "calculation_strategy": "fixed",
  "measure_method": "manual",
  "measure_device": "N/A",
  "created_at": "2026-03-20T00:00:00Z",
  "fields": {
    "load_entity": {
      "label": "Load percentage entity",
      "description": "The NUT sensor showing UPS load percentage (0-100%)",
      "selector": {
        "entity": {
          "domain": "sensor"
        }
      }
    },
    "nominal_va": {
      "label": "Nominal Power (VA)",
      "description": "The VA rating of your UPS",
      "selector": {
        "number": {
          "min": 100,
          "max": 10000
        }
      }
    },
    "power_factor": {
      "label": "Power Factor",
      "description": "Ratio of real power to apparent power",
      "selector": {
        "number": {
          "min": 0.1,
          "max": 1.0,
          "step": 0.1
        }
      }
    }
  },
  "fixed_config": {
    "power": "{{ states('[[load_entity]]') | float(0) / 100 * [[nominal_va]] | float(0) * [[power_factor]] | float(0.6) }}"
  }
}
